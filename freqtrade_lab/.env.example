# Hyperliquid credentials
HL_WALLET_ADDRESS=0x...
HL_PRIVATE_KEY=0x...

# FreqUI / API server
FREQTRADE_JWT_SECRET=change_me_to_a_random_string
FREQTRADE_API_USER=admin
FREQTRADE_API_PASS=change_me_to_a_strong_password

# Strategy parameters
STREAK_TRIGGER=6
EMA_PERIOD=100
RISK_PCT=0.01
STOP_ATR_MULT=1.0
TP_ATR_MULT=1.5
MAX_POSITION_PCT=0.20
LEVERAGE=1

# HYPE regime pullback paper-trading candidate.
RPC_PAIR_ALLOWLIST=HYPE/USDC:USDC
RPC_USE_EMA_EXIT=false
RPC_USE_REGIME_EXIT=false
RPC_ATR_TP=2.5
RPC_ATR_STOP=1.0
RPC_MAX_HOLD=72

# Optional free external context.
# Keep disabled for pure OHLCV/offline baselines. When enabled, strategies read
# local files from FT_CONTEXT_DIR and merge ctx_* columns by candle date.
FT_CONTEXT_ENABLED=false
FT_CONTEXT_DIR=user_data/data/context
FT_CONTEXT_MAX_STALENESS_HOURS=36
FT_CONTEXT_FEAR_MIN=20
FT_CONTEXT_STABLECOIN_MIN_CHG_1D=-0.01
FT_CONTEXT_DXY_MAX_CHG_1D=0.015
FT_CONTEXT_VIX_MAX_CHG_1D=0.10
FT_CONTEXT_FUNDING_ABS_MAX=0.0015
