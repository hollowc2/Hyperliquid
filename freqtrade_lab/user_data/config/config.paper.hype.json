{
  "max_open_trades": 1,
  "stake_currency": "USDC",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "minimal_roi": {
    "0": 100
  },
  "stoploss": -0.05,
  "stoploss_on_exchange": false,
  "trailing_stop": false,
  "timeframe": "5m",
  "dry_run": true,
  "dry_run_wallet": 1000,
  "cancel_open_orders_on_exit": true,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "liquidation_buffer": 0.05,
  "futures_funding_rate": 0,
  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "stoploss": "limit",
    "stoploss_on_exchange": false
  },
  "order_time_in_force": {
    "entry": "GTC",
    "exit": "GTC"
  },
  "entry_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_ratio": 0
    }
  },
  "exit_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0
  },
  "exchange": {
    "name": "hyperliquid",
    "key": "${HL_WALLET_ADDRESS}",
    "secret": "${HL_PRIVATE_KEY}",
    "ccxt_config": {
      "options": {
        "defaultType": "swap"
      }
    },
    "ccxt_async_config": {
      "options": {
        "defaultType": "swap"
      }
    },
    "pair_whitelist": [
      "HYPE/USDC:USDC"
    ],
    "pair_blacklist": []
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "changeme",
    "CORS_origins": [],
    "username": "changeme",
    "password": "changeme"
  },
  "bot_name": "hype_regime_pullback_paper",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  }
}
