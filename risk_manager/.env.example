# Telegram bot credentials
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Hyperliquid wallet to monitor
HL_WALLET_ADDRESS=0xYourWalletAddressHere

# Alert thresholds (optional — defaults shown)
LIQ_DISTANCE_THRESHOLD=5.0         # % from liquidation price before alerting
TOTAL_RISK_THRESHOLD=1000.0        # total USD risk before alerting
POSITION_RISK_PERCENT_THRESHOLD=5.0  # per-position risk as % of withdrawable
